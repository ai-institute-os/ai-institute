# AISelect — Vercel environment variables
# Set in: Vercel → Project → Settings → Environment Variables
# Add each key individually (Vercel doesn't support .env file upload directly)

# ── Auth ───────────────────────────────────────────────────
CLIENT_SECRET=                     # generate: openssl rand -hex 32
# NOTE: CLIENT_SECRET MUST be set — app refuses to start without it (instrumentation.ts check)

# ── Database (Turso) ───────────────────────────────────────
TURSO_DATABASE_URL=libsql://aiselect-production-xxx.turso.io
                                   # turso db show aiselect-production --url
TURSO_AUTH_TOKEN=                  # turso db tokens create aiselect-production

# ── Claude AI (screening) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-          # console.anthropic.com → API Keys

# ── Resend (email) ─────────────────────────────────────────
RESEND_API_KEY=re_                 # same key as AIScore, or create a separate one
RESEND_FROM_EMAIL=kontakt@aiselect.dk

# ── Stripe (abonnementer) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_STARTER=price_        # AISelect Starter månedspris
STRIPE_PRICE_PRO=price_            # AISelect Pro månedspris
STRIPE_PRICE_ENTERPRISE=price_     # AISelect Enterprise månedspris

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGIN=https://aiselect.dk

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.aiselect.dk

# Calendly booking link for AISelect consultations
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/research-aiscore/30min
